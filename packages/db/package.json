{
  "name": "@acme/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "push": "pnpm with-env drizzle-kit push --force",
    "fix-units": "pnpm with-env tsx src/fix-units.ts",
    "seed": "pnpm with-env tsx src/seed.ts",
    "seed-admin": "pnpm with-env tsx src/seed-admin.ts",
    "seed-cards": "pnpm with-env tsx src/seed-cards.ts",
    "studio": "pnpm with-env drizzle-kit studio",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@vercel/postgres": "^0.10.0",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "better-auth": "catalog:",
    "drizzle-kit": "^0.31.5",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.19.4",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config"
}
